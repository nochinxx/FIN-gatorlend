# Web app variables.
# `NEXT_PUBLIC_` values are exposed to the browser and must be safe for a public repo.
# Private server-only keys must never use the `NEXT_PUBLIC_` prefix.

# Browser-safe values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_XRPL_NETWORK=testnet
NEXT_PUBLIC_XRPL_TESTNET_RPC_URL=wss://s.altnet.rippletest.net:51233
NEXT_PUBLIC_XRPL_TESTNET_HTTP_URL=https://s.altnet.rippletest.net:51234

# Server-only placeholders
# These are intentionally not prefixed with `NEXT_PUBLIC_`.
# Do not expose service role keys, issuer seeds, or privileged XRPL secrets to the client.
SUPABASE_URL=
SUPABASE_ANON_KEY=
XRPL_TESTNET_RPC_URL=wss://s.altnet.rippletest.net:51233
XRPL_TESTNET_HTTP_URL=https://s.altnet.rippletest.net:51234
SUPABASE_SERVICE_ROLE_KEY=
XRPL_ISSUER_SEED=

# TODO: add private server variables here only when a server-side integration needs them.
