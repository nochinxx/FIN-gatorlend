# Workspace-level variables.
# Do not commit real secrets. Keep privileged values out of the web client.

XRPL_NETWORK=testnet
XRPL_TESTNET_RPC_URL=wss://s.altnet.rippletest.net:51233
XRPL_TESTNET_HTTP_URL=https://s.altnet.rippletest.net:51234
XRPL_TESTNET_FAUCET_URL=https://faucet.altnet.rippletest.net/accounts

# Server-side Supabase values belong outside client bundles.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Public site URL used for Supabase auth redirects.
# Local development:
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production:
# NEXT_PUBLIC_SITE_URL=https://fin-gatorlend.com
# Vercel production must define NEXT_PUBLIC_SITE_URL=https://fin-gatorlend.com.
# Supabase Auth redirect URLs must allow both local and production callback URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# TODO: add server-only variables here if/when backend jobs or server actions need them.
