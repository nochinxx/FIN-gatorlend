{
  "name": "fin-gatorlend",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "dev:web": "pnpm --filter @gatorlend/web dev",
    "build": "pnpm -r build",
    "test": "pnpm --filter @gatorlend/core test && vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm --filter @gatorlend/web lint"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
